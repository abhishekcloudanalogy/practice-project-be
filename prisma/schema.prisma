generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
  MICROSOFT
}

enum ContactType {
  PRIMARY
  SECONDARY
}

model User {
  id                String       @id @default(cuid())
  name              String?
  email             String       @unique
  password          String?
  image             String?
  role              UserRole     @default(USER)
  isActive          Boolean      @default(true)
  authProvider      AuthProvider @default(CREDENTIALS)
  providerAccountId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  contacts        Contact[]
  userContacts    UserContact[]
  refreshTokens   RefreshToken[]
  pdfDocuments    PdfDocument[]
  extractedTables ExtractedTable[]
  extractedRows   ExtractedRow[]

  @@unique([authProvider, providerAccountId])
}

model PdfDocument {
  id            String   @id @default(uuid())
  userId        String
  fileName      String
  filePath      String
  contentHash   String?
  extractedText String?
  extractedData Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  extractedTables ExtractedTable[]

  @@index([userId])
}

model ExtractedTable {
  id            String   @id @default(uuid())
  userId        String
  pdfDocumentId String
  title         String?
  tableHash     String
  schemaHash    String
  columns       Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pdfDocument PdfDocument @relation(fields: [pdfDocumentId], references: [id], onDelete: Cascade)
  extractedRows ExtractedRow[]

  @@index([userId])
  @@index([pdfDocumentId])
  @@index([userId, schemaHash])
  @@unique([userId, tableHash], name: "extracted_table_user_table_hash_unique")
}

model ExtractedRow {
  id             String   @id @default(cuid())
  userId         String
  extractedTableId String
  rowHash        String
  rowData        Json
  rowIndex       Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  extractedTable ExtractedTable @relation(fields: [extractedTableId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([extractedTableId])
  @@unique([extractedTableId, rowHash], name: "extracted_row_table_row_hash_unique")
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  revoked    Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Contact {
  id               String   @id @default(cuid())

  firstName        String
  lastName         String?

  email            String
  primaryContact   String
  secondaryContact String?

  subject          String
  message          String


  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)


  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt


  @@index([email])
  @@index([userId])
  @@index([createdAt])
}

model UserContact {
  id               String      @id @default(cuid())
  firstName        String
  lastName         String?
  email            String
  primaryContact   String
  secondaryContact String?
  company          String?
  notes            String?
  contactType      ContactType @default(PRIMARY)
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([userId])
  @@index([email])
  @@index([contactType])
  @@unique([userId, email], name: "user_contact_user_email_unique")
  @@unique([userId, primaryContact], name: "user_contact_user_primary_contact_unique")
}
